generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  ADMIN
  TEACHER
  TA
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
  SUSPENDED
}

enum ModuleItemType {
  LESSON
  ASSIGNMENT
  QUIZ
  CODE_EXERCISE
  PRACTICE_TEST
  FILE
  EXTERNAL_URL
}

enum CompletionType {
  VIEW
  SUBMIT
  MIN_SCORE
}

enum AssignmentType {
  TEXT
  FILE
  BOTH
}

enum ExerciseStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum CodeLanguage {
  PYTHON3
  JAVASCRIPT
  CPP17
  WEB
  SCRATCH
}

enum CodeSubmissionStatus {
  PENDING
  PROCESSING
  ACCEPTED
  PARTIAL
  WRONG_ANSWER
  COMPILE_ERROR
  RUNTIME_ERROR
  TIME_LIMIT
  INTERNAL_ERROR
  MANUAL_REVIEW
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  LATE
  GRADED
  RETURNED
}

enum LatePolicy {
  NONE
  ALLOW
  DEDUCT
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum PracticeTestStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum PracticeQuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE_MULTI
  SHORT_ANSWER
}

enum QuestionType {
  MULTIPLE_CHOICE_SINGLE
  MULTIPLE_CHOICE_MULTIPLE
  TRUE_FALSE
  TRUE_FALSE_MULTI
  ESSAY
  CODE_PYTHON
  CODE_CPP
  CODE_WEB
  PARSONS
  CODE_FILL
  CODE_DEBUG_PYTHON
  CODE_DEBUG_CPP
  ORDERING
  MATCHING
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum NotificationType {
  QUIZ_GRADED
  ASSIGNMENT_GRADED
  CODE_GRADED
  COURSE_ENROLLED
  ASSIGNMENT_DUE_SOON
  ANNOUNCEMENT
  FORUM_REPLY
}

enum ActivityAction {
  VIEW_COURSE
  VIEW_LESSON
  START_QUIZ
  SUBMIT_QUIZ
  VIEW_PRACTICE_TEST
  START_PRACTICE_TEST
  SUBMIT_PRACTICE_TEST
  VIEW_ASSIGNMENT
  SUBMIT_ASSIGNMENT
  SUBMIT_CODE
  VIEW_EXERCISE
  LOGIN
}

// Mức độ thành thạo năng lực (thứ tự tăng dần). Điểm quy đổi map ở @lumibach/types.
enum CompetencyLevel {
  NO_EVIDENCE // Không có minh chứng
  BEGINNING // Chưa thành thạo
  APPROACHING // Gần thành thạo
  PROFICIENT // Thành thạo
  ADVANCED // Vượt thành thạo
}

// Chế độ tương tác nhóm của khoá học.
enum GroupMode {
  NO_GROUPS // Không có nhóm
  SEPARATE_GROUPS // Nhóm riêng biệt (chỉ thấy nhóm mình)
  VISIBLE_GROUPS // Nhóm hiện hữu (thấy nhóm khác, chỉ xem)
}

// ============================================================
// AUTHENTICATION MODELS
// ============================================================

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  username     String? @unique
  passwordHash String

  // Thông tin cá nhân
  firstName   String
  lastName    String
  fullName    String? // tên đầy đủ kiểu Việt Nam: "Nguyễn Văn A"
  avatar      String? // URL ảnh trên MinIO
  phone       String?
  dateOfBirth DateTime?

  // Vai trò và trạng thái
  role          UserRole   @default(STUDENT)
  status        UserStatus @default(PENDING)
  emailVerified DateTime?

  // Metadata
  lastLoginAt DateTime?
  loginCount  Int       @default(0)
  preferences Json? // theme, language, notifications

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  passwordResets         PasswordReset[]
  emailTokens            EmailVerificationToken[]
  auditLogs              AuditLog[]
  activityLogs           ActivityLog[]
  ownedCourses           Course[]                 @relation("CourseOwner")
  enrollments            Enrollment[]
  taAssignments          TeachingAssistant[]
  coTeachingCourses      CourseCoTeacher[]        @relation("CoTeacher")
  quizAttempts           QuizAttempt[]
  practiceTestAttempts   PracticeTestAttempt[]
  submissions            Submission[]             @relation("SubmissionStudent")
  notifications          Notification[]
  notificationPreference NotificationPreference?
  forumTopics            ForumTopic[]             @relation("ForumTopicAuthor")
  forumPosts             ForumPost[]              @relation("ForumPostAuthor")
  competencyAssessments  CompetencyAssessment[]
  groupMemberships       GroupMember[]
  portfolioReflections   PortfolioReflection[]

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([status])
  @@index([deletedAt])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userRole   String?
  action     String
  resource   String?
  resourceId String?
  changes    Json? // before/after state
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resource, resourceId])
  @@index([createdAt])
}

// ============================================================
// COURSE MODULE
// ============================================================

model CourseCategory {
  id          String  @id @default(cuid())
  name        String
  slug        String
  description String? @db.Text
  sortOrder   Int     @default(0)

  parentId String?
  parent   CourseCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children CourseCategory[] @relation("CategoryHierarchy")

  courses Course[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([parentId, slug])
  @@index([parentId])
  @@index([deletedAt])
}

model Course {
  id             String       @id @default(cuid())
  name           String
  shortName      String?
  slug           String       @unique
  description    String?      @db.Text
  thumbnail      String?
  subject        String?
  status         CourseStatus @default(DRAFT)
  isPublic       Boolean      @default(false)
  enrollmentCode String?      @unique
  groupMode      GroupMode    @default(NO_GROUPS)

  startDate DateTime?
  endDate   DateTime?
  settings  Json?

  categoryId String
  category   CourseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  ownerId String
  owner   User   @relation("CourseOwner", fields: [ownerId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?
  archivedAt  DateTime?
  deletedAt   DateTime?

  enrollments          Enrollment[]
  teachingAssistants   TeachingAssistant[]
  coTeachers           CourseCoTeacher[]
  modules              Module[]
  assignments          Assignment[]
  quizzes              Quiz[]
  practiceTests        PracticeTest[]
  questions            Question[]
  questionCategories   QuestionCategory[]
  exercises            CodeExercise[]
  activityLogs         ActivityLog[]
  forumTopics          ForumTopic[]
  competencyCategories CompetencyCategory[]
  groups               Group[]
  groupings            Grouping[]
  portfolioReflections PortfolioReflection[]

  @@index([slug])
  @@index([ownerId])
  @@index([categoryId])
  @@index([status])
  @@index([deletedAt])
}

model Enrollment {
  id       String           @id @default(cuid())
  userId   String
  courseId String
  status   EnrollmentStatus @default(ACTIVE)

  enrolledAt   DateTime  @default(now())
  completedAt  DateTime?
  progress     Float     @default(0)
  lastAccessAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
}

model TeachingAssistant {
  id          String   @id @default(cuid())
  userId      String
  courseId    String
  assignedAt  DateTime @default(now())
  assignedBy  String?
  permissions Json?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model CourseCoTeacher {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  assignedAt DateTime @default(now())
  assignedBy String?

  user   User   @relation("CoTeacher", fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

// ============================================================
// CONTENT MODULE
// ============================================================

model Module {
  id          String    @id @default(cuid())
  courseId    String
  name        String
  description String?   @db.Text
  position    Int
  isPublished Boolean   @default(false)
  unlockAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  items  ModuleItem[]

  @@index([courseId])
  @@index([courseId, position])
}

model ModuleItem {
  id                String         @id @default(cuid())
  moduleId          String
  type              ModuleItemType
  position          Int
  title             String
  lessonId          String?
  externalUrl       String?
  isPublished       Boolean        @default(false)
  requireCompletion Boolean        @default(false)
  completionType    CompletionType @default(VIEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignmentId   String?
  quizId         String?
  codeExerciseId String?
  practiceTestId String?

  // Cài đặt nhóm theo từng hoạt động (Moodle-style)
  // NO_GROUPS: mọi HS xem được. VISIBLE_GROUPS: chỉ HS thuộc visibleGroups xem.
  // SEPARATE_GROUPS: dùng grouping (chia nhóm trong hoạt động — group submission cho assignment).
  groupMode  GroupMode @default(NO_GROUPS)
  groupingId String?

  module        Module                 @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lesson        Lesson?                @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  assignment    Assignment?            @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  quiz          Quiz?                  @relation(fields: [quizId], references: [id], onDelete: SetNull)
  codeExercise  CodeExercise?          @relation(fields: [codeExerciseId], references: [id], onDelete: SetNull)
  practiceTest  PracticeTest?          @relation(fields: [practiceTestId], references: [id], onDelete: SetNull)
  grouping      Grouping?              @relation(fields: [groupingId], references: [id], onDelete: SetNull)
  completions   ModuleItemCompletion[]
  visibleGroups ModuleItemGroup[]

  @@index([moduleId])
  @@index([moduleId, position])
  @@index([groupingId])
}

// Bảng nối ModuleItem ↔ Group cho chế độ VISIBLE_GROUPS (chỉ nhóm được liệt kê có thể xem).
model ModuleItemGroup {
  id           String   @id @default(cuid())
  moduleItemId String
  groupId      String
  createdAt    DateTime @default(now())

  moduleItem ModuleItem @relation(fields: [moduleItemId], references: [id], onDelete: Cascade)
  group      Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([moduleItemId, groupId])
  @@index([moduleItemId])
  @@index([groupId])
}

model Lesson {
  id               String @id @default(cuid())
  title            String
  content          String @db.Text
  estimatedMinutes Int?
  createdBy        String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  moduleItems ModuleItem[]
  attachments LessonAttachment[]
}

model LessonAttachment {
  id         String @id @default(cuid())
  lessonId   String
  name       String
  url        String
  mimeType   String
  size       Int
  uploadedBy String

  createdAt DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model ModuleItemCompletion {
  id           String   @id @default(cuid())
  userId       String
  moduleItemId String
  completedAt  DateTime @default(now())

  moduleItem ModuleItem @relation(fields: [moduleItemId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleItemId])
  @@index([userId])
  @@index([moduleItemId])
}

// ============================================================
// ASSIGNMENT MODULE
// ============================================================

model Assignment {
  id           String           @id @default(cuid())
  courseId     String
  title        String
  instructions String           @db.Text
  type         AssignmentType   @default(TEXT)
  status       AssignmentStatus @default(DRAFT)

  maxScore Float @default(100)
  weight   Float @default(1)

  availableFrom DateTime?
  dueDate       DateTime?
  lateDeadline  DateTime?
  latePolicy    LatePolicy @default(NONE)
  latePenalty   Float?

  allowResubmit Boolean @default(false)
  maxAttempts   Int?

  // Giới hạn upload file khi nộp bài (type FILE/BOTH). null = dùng mặc định hệ thống.
  maxFileSizeMb Int?
  maxFiles      Int?

  // Nộp bài theo nhóm: 1 thành viên nộp = cả nhóm tính đã nộp, chấm 1 lần cho cả nhóm.
  groupSubmission Boolean @default(false)
  groupingId      String?

  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?
  deletedAt   DateTime?

  course                Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  grouping              Grouping?              @relation(fields: [groupingId], references: [id], onDelete: SetNull)
  moduleItems           ModuleItem[]
  submissions           Submission[]
  rubric                Rubric?
  competencyLinks       ActivityCompetency[]
  competencyAssessments CompetencyAssessment[]

  @@index([courseId])
  @@index([status])
  @@index([dueDate])
  @@index([deletedAt])
}

model Submission {
  id            String           @id @default(cuid())
  assignmentId  String
  studentId     String
  content       String?          @db.Text
  status        SubmissionStatus @default(DRAFT)
  attemptNumber Int              @default(1)

  submittedAt DateTime?
  score       Float?
  feedback    String?   @db.Text
  gradedAt    DateTime?
  gradedBy    String?

  // Khi nộp theo nhóm: nhóm mà bài nộp này đại diện (mọi thành viên dùng chung).
  groupId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      User             @relation("SubmissionStudent", fields: [studentId], references: [id])
  group        Group?           @relation(fields: [groupId], references: [id], onDelete: SetNull)
  files        SubmissionFile[]
  rubricGrades RubricGrade[]

  @@unique([assignmentId, studentId, attemptNumber])
  @@index([assignmentId])
  @@index([studentId])
  @@index([status])
  @@index([groupId])
}

// ── Rubric ───────────────────────────────────────────────────

model Rubric {
  id             String   @id @default(cuid())
  assignmentId   String?  @unique
  codeExerciseId String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignment   Assignment?       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  codeExercise CodeExercise?     @relation(fields: [codeExerciseId], references: [id], onDelete: Cascade)
  criteria     RubricCriterion[]
  // App invariant: exactly one of (assignmentId, codeExerciseId) is non-null.
}

model RubricCriterion {
  id          String  @id @default(cuid())
  rubricId    String
  name        String
  description String?
  position    Int     @default(0)

  rubric Rubric        @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  levels RubricLevel[]
  grades RubricGrade[]

  @@index([rubricId])
}

model RubricLevel {
  id          String  @id @default(cuid())
  criterionId String
  label       String
  points      Float
  description String?
  position    Int     @default(0)

  criterion RubricCriterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  grades    RubricGrade[]

  @@index([criterionId])
}

model RubricGrade {
  id               String   @id @default(cuid())
  submissionId     String?
  codeSubmissionId String?
  criterionId      String
  levelId          String
  gradedBy         String
  gradedAt         DateTime @default(now())

  submission     Submission?     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  codeSubmission CodeSubmission? @relation(fields: [codeSubmissionId], references: [id], onDelete: Cascade)
  criterion      RubricCriterion @relation(fields: [criterionId], references: [id])
  level          RubricLevel     @relation(fields: [levelId], references: [id])

  @@unique([submissionId, criterionId])
  @@unique([codeSubmissionId, criterionId])
  @@index([submissionId])
  @@index([codeSubmissionId])
}

// ── Submission File ──────────────────────────────────────────

model SubmissionFile {
  id           String   @id @default(cuid())
  submissionId String
  name         String
  url          String
  mimeType     String
  size         Int
  uploadedBy   String
  createdAt    DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

// ── Quiz Engine ──────────────────────────────────────────────

model Quiz {
  id          String     @id @default(cuid())
  courseId    String
  title       String
  description String?    @db.Text
  status      QuizStatus @default(DRAFT)

  timeLimit        Int? // phút, null = không giới hạn
  maxAttempts      Int? // null = không giới hạn
  passingScore     Float? // null = không yêu cầu
  shuffleQuestions Boolean @default(false)
  shuffleAnswers   Boolean @default(false)
  showResults      Boolean @default(true)

  availableFrom DateTime?
  dueDate       DateTime?

  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?
  deletedAt   DateTime?

  course                Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions             QuizQuestion[]
  attempts              QuizAttempt[]
  moduleItems           ModuleItem[]
  competencyLinks       ActivityCompetency[]
  competencyAssessments CompetencyAssessment[]

  @@index([courseId])
  @@index([status])
  @@index([deletedAt])
}

model QuestionCategory {
  id        String   @id @default(cuid())
  courseId  String
  name      String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions Question[]

  @@index([courseId])
}

model Question {
  id          String       @id @default(cuid())
  courseId    String
  categoryId  String?
  type        QuestionType
  content     String       @db.Text
  explanation String?      @db.Text
  points      Float        @default(1)

  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // For CODE_* question types
  starterCode  String? @db.Text
  solutionCode String? @db.Text
  timeLimit    Int? // seconds per test case
  memoryLimit  Int? // KB

  course    Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  category  QuestionCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  options   QuestionOption[]
  quizzes   QuizQuestion[]
  answers   Answer[]
  testCases QuestionTestCase[]

  @@index([courseId])
  @@index([categoryId])
  @@index([type])
  @@index([deletedAt])
}

model QuestionTestCase {
  id             String  @id @default(cuid())
  questionId     String
  input          String  @db.Text
  expectedOutput String  @db.Text
  isHidden       Boolean @default(false)
  points         Float   @default(1)
  position       Int     @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model QuestionOption {
  id         String  @id @default(cuid())
  questionId String
  content    String
  isCorrect  Boolean @default(false)
  position   Int     @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model QuizQuestion {
  id         String @id @default(cuid())
  quizId     String
  questionId String
  position   Int    @default(0)
  points     Float? // override câu hỏi gốc

  quiz     Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([quizId, questionId])
  @@index([quizId])
}

model QuizAttempt {
  id        String        @id @default(cuid())
  quizId    String
  studentId String
  status    AttemptStatus @default(IN_PROGRESS)

  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  score       Float?
  maxScore    Float?

  quiz    Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student User     @relation(fields: [studentId], references: [id])
  answers Answer[]

  @@index([quizId])
  @@index([studentId])
}

// ── Code Exercise Module ─────────────────────────────────────

model CodeExercise {
  id          String         @id @default(cuid())
  courseId    String
  title       String
  description String?        @db.Text
  language    CodeLanguage
  status      ExerciseStatus @default(DRAFT)

  // For PYTHON3 / JAVASCRIPT / CPP17
  starterCode  String? @db.Text
  solutionCode String? @db.Text
  timeLimit    Int     @default(3) // seconds per test case
  memoryLimit  Int     @default(262144) // KB = 256 MB

  // For WEB (HTML + CSS + JS)
  starterHtml String? @db.Text
  starterCss  String? @db.Text
  starterJs   String? @db.Text

  // For SCRATCH (.sb3 file URL on MinIO)
  starterFileUrl String?

  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  course                Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  moduleItems           ModuleItem[]
  testCases             TestCase[]
  submissions           CodeSubmission[]
  rubric                Rubric?
  competencyLinks       ActivityCompetency[]
  competencyAssessments CompetencyAssessment[]

  @@index([courseId])
  @@index([status])
  @@index([deletedAt])
}

model TestCase {
  id             String  @id @default(cuid())
  codeExerciseId String
  label          String?
  input          String  @db.Text
  expectedOutput String  @db.Text
  isHidden       Boolean @default(true)
  points         Float   @default(1)
  position       Int     @default(0)

  codeExercise CodeExercise     @relation(fields: [codeExerciseId], references: [id], onDelete: Cascade)
  results      TestCaseResult[]

  @@index([codeExerciseId])
}

model CodeSubmission {
  id             String               @id @default(cuid())
  codeExerciseId String
  studentId      String
  language       CodeLanguage
  code           String               @db.Text // JSON for WEB: {html,css,js}
  status         CodeSubmissionStatus @default(PENDING)
  score          Float?
  maxScore       Float?
  feedback       String?              @db.Text
  attemptNumber  Int                  @default(1)
  submittedAt    DateTime             @default(now())
  gradedAt       DateTime?
  gradedBy       String?

  codeExercise CodeExercise     @relation(fields: [codeExerciseId], references: [id], onDelete: Cascade)
  results      TestCaseResult[]
  rubricGrades RubricGrade[]

  @@index([codeExerciseId])
  @@index([studentId])
}

model TestCaseResult {
  id            String               @id @default(cuid())
  submissionId  String
  testCaseId    String
  status        CodeSubmissionStatus
  stdout        String?              @db.Text
  stderr        String?              @db.Text
  compileOutput String?              @db.Text
  time          Float? // seconds
  memory        Int? // KB
  score         Float?
  judge0Token   String?

  submission CodeSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  testCase   TestCase       @relation(fields: [testCaseId], references: [id])

  @@unique([submissionId, testCaseId])
  @@index([submissionId])
}

model Answer {
  id         String @id @default(cuid())
  attemptId  String
  questionId String

  selectedOptionIds String? // JSON: ["optId1","optId2"] cho MCQ
  booleanAnswer     Boolean? // cho TRUE_FALSE
  textAnswer        String?  @db.Text // cho ESSAY

  isCorrect Boolean?
  score     Float?
  feedback  String?  @db.Text

  attempt  QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id])

  @@unique([attemptId, questionId])
  @@index([attemptId])
}

// ============================================================
// PRACTICE TEST MODULE
// ============================================================

model PracticeTest {
  id          String             @id @default(cuid())
  courseId    String
  title       String
  description String?            @db.Text
  status      PracticeTestStatus @default(DRAFT)

  pdfUrl      String
  pdfName     String
  pdfMimeType String @default("application/pdf")
  pdfSize     Int    @default(0)

  timeLimit   Int?
  maxAttempts Int?
  showResults Boolean @default(true)

  availableFrom DateTime?
  dueDate       DateTime?

  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?
  deletedAt   DateTime?

  course                Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  moduleItems           ModuleItem[]
  questions             PracticeTestQuestion[]
  attempts              PracticeTestAttempt[]
  competencyLinks       ActivityCompetency[]
  competencyAssessments CompetencyAssessment[]

  @@index([courseId])
  @@index([status])
  @@index([deletedAt])
}

model PracticeTestQuestion {
  id             String               @id @default(cuid())
  practiceTestId String
  type           PracticeQuestionType
  position       Int                  @default(0)
  prompt         String?              @db.Text
  points         Float                @default(1)
  optionCount    Int                  @default(4)
  statementCount Int                  @default(4)
  correctAnswer  Json
  caseSensitive  Boolean              @default(false)

  practiceTest PracticeTest         @relation(fields: [practiceTestId], references: [id], onDelete: Cascade)
  answers      PracticeTestAnswer[]

  @@index([practiceTestId])
  @@index([type])
}

model PracticeTestAttempt {
  id             String        @id @default(cuid())
  practiceTestId String
  studentId      String
  status         AttemptStatus @default(GRADED)

  startedAt   DateTime @default(now())
  submittedAt DateTime @default(now())
  score       Float?
  maxScore    Float?

  practiceTest PracticeTest         @relation(fields: [practiceTestId], references: [id], onDelete: Cascade)
  student      User                 @relation(fields: [studentId], references: [id])
  answers      PracticeTestAnswer[]

  @@index([practiceTestId])
  @@index([studentId])
}

model PracticeTestAnswer {
  id         String @id @default(cuid())
  attemptId  String
  questionId String

  selectedOption   String?
  statementAnswers Json?
  textAnswer       String? @db.Text

  isCorrect Boolean?
  score     Float?

  attempt  PracticeTestAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question PracticeTestQuestion @relation(fields: [questionId], references: [id])

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}

// ============================================================
// NOTIFICATION SYSTEM
// ============================================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?          @db.Text
  link      String?
  isRead    Boolean          @default(false)
  emailSent Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model NotificationPreference {
  id     String @id @default(cuid())
  userId String @unique

  inAppEnabled          Boolean @default(true)
  emailEnabled          Boolean @default(true)
  emailQuizGraded       Boolean @default(true)
  emailAssignmentGraded Boolean @default(true)
  emailCodeGraded       Boolean @default(true)
  emailEnrolled         Boolean @default(true)
  emailDueSoon          Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// ACTIVITY LOG
// ============================================================

model ActivityLog {
  id           String         @id @default(cuid())
  userId       String
  courseId     String?
  action       ActivityAction
  resourceType String? // "lesson" | "quiz" | "assignment" | "exercise"
  resourceId   String?
  resourceName String? // denormalized title for display
  metadata     Json?
  ipAddress    String?
  createdAt    DateTime       @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([courseId])
  @@index([action])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([courseId, createdAt])
}

// ============================================================
// DISCUSSION FORUM
// ============================================================

model ForumTopic {
  id        String   @id @default(cuid())
  courseId  String
  authorId  String
  title     String
  isPinned  Boolean  @default(false)
  isLocked  Boolean  @default(false)
  viewCount Int      @default(0)
  groupId   String? // chủ đề thuộc nhóm nào (theo chế độ nhóm của khoá học)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  author User        @relation("ForumTopicAuthor", fields: [authorId], references: [id])
  group  Group?      @relation(fields: [groupId], references: [id], onDelete: SetNull)
  posts  ForumPost[]

  @@index([courseId])
  @@index([authorId])
  @@index([courseId, createdAt])
  @@index([groupId])
}

model ForumPost {
  id        String   @id @default(cuid())
  topicId   String
  authorId  String
  content   String   @db.Text
  isAnswer  Boolean  @default(false)
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topic   ForumTopic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  author  User        @relation("ForumPostAuthor", fields: [authorId], references: [id])
  parent  ForumPost?  @relation("ForumPostReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies ForumPost[] @relation("ForumPostReplies")

  @@index([topicId])
  @@index([authorId])
  @@index([topicId, createdAt])
}

// ============================================================
// COMPETENCY MODULE — chấm điểm năng lực (CBE)
// ============================================================

// Danh mục năng lực — khởi tạo trong từng khoá học.
model CompetencyCategory {
  id          String   @id @default(cuid())
  courseId    String
  name        String
  description String?  @db.Text
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course     Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  indicators CompetencyIndicator[]

  @@index([courseId])
}

// Chỉ báo năng lực — thuộc một danh mục.
model CompetencyIndicator {
  id          String   @id @default(cuid())
  categoryId  String
  code        String? // mã chỉ báo (tuỳ chọn), vd "1.1"
  name        String   @db.Text // nội dung chỉ báo
  description String?  @db.Text
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category      CompetencyCategory     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  activityLinks ActivityCompetency[]
  assessments   CompetencyAssessment[]

  @@index([categoryId])
}

// Liên kết chỉ báo ↔ hoạt động học tập (đa hình: đúng 1 trong 4 FK non-null).
model ActivityCompetency {
  id          String   @id @default(cuid())
  indicatorId String
  createdAt   DateTime @default(now())

  assignmentId   String?
  quizId         String?
  codeExerciseId String?
  practiceTestId String?

  indicator    CompetencyIndicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  assignment   Assignment?         @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  quiz         Quiz?               @relation(fields: [quizId], references: [id], onDelete: Cascade)
  codeExercise CodeExercise?       @relation(fields: [codeExerciseId], references: [id], onDelete: Cascade)
  practiceTest PracticeTest?       @relation(fields: [practiceTestId], references: [id], onDelete: Cascade)

  @@unique([indicatorId, assignmentId])
  @@unique([indicatorId, quizId])
  @@unique([indicatorId, codeExerciseId])
  @@unique([indicatorId, practiceTestId])
  @@index([indicatorId])
  @@index([assignmentId])
  @@index([quizId])
  @@index([codeExerciseId])
  @@index([practiceTestId])
}

// Đánh giá năng lực của 1 học sinh cho 1 chỉ báo trên 1 hoạt động.
// loại minh chứng (evidenceType) tham chiếu danh sách 5 nhóm ở @lumibach/types.
model CompetencyAssessment {
  id           String          @id @default(cuid())
  indicatorId  String
  studentId    String
  level        CompetencyLevel
  evidenceType String? // key thuộc EVIDENCE_TYPES
  note         String?         @db.Text

  assignmentId   String?
  quizId         String?
  codeExerciseId String?
  practiceTestId String?

  gradedBy  String
  gradedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  indicator    CompetencyIndicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  student      User                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignment   Assignment?         @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  quiz         Quiz?               @relation(fields: [quizId], references: [id], onDelete: Cascade)
  codeExercise CodeExercise?       @relation(fields: [codeExerciseId], references: [id], onDelete: Cascade)
  practiceTest PracticeTest?       @relation(fields: [practiceTestId], references: [id], onDelete: Cascade)

  @@unique([indicatorId, studentId, assignmentId])
  @@unique([indicatorId, studentId, quizId])
  @@unique([indicatorId, studentId, codeExerciseId])
  @@unique([indicatorId, studentId, practiceTestId])
  @@index([studentId])
  @@index([indicatorId])
  @@index([assignmentId])
  @@index([quizId])
  @@index([codeExerciseId])
  @@index([practiceTestId])
}

// ============================================================
// GROUP MODULE — phân nhóm trong khoá học
// ============================================================

// Nhóm — thuộc một khoá học. Một học sinh có thể ở nhiều nhóm (qua nhiều grouping).
model Group {
  id          String   @id @default(cuid())
  courseId    String
  name        String
  description String?  @db.Text
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course           Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  members          GroupMember[]
  groupingLinks    GroupingGroup[]
  submissions      Submission[]
  forumTopics      ForumTopic[]
  moduleItemAccess ModuleItemGroup[]

  @@index([courseId])
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

// Phân nhóm — tập hợp nhiều Nhóm lại để giao chung một hoạt động.
model Grouping {
  id          String   @id @default(cuid())
  courseId    String
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  groups      GroupingGroup[]
  assignments Assignment[]
  moduleItems ModuleItem[]

  @@index([courseId])
}

model GroupingGroup {
  id         String @id @default(cuid())
  groupingId String
  groupId    String

  grouping Grouping @relation(fields: [groupingId], references: [id], onDelete: Cascade)
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupingId, groupId])
  @@index([groupingId])
  @@index([groupId])
}

// ============================================================
// PORTFOLIO MODULE — hồ sơ học tập cá nhân
// ============================================================

// Tự đánh giá / phản ánh của học sinh (một phần của hồ sơ học tập).
model PortfolioReflection {
  id        String   @id @default(cuid())
  courseId  String
  studentId String
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([courseId, studentId])
}
