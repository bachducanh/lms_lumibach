{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "REDIS_URL",
    "AUTH_SECRET",
    "NEXTAUTH_URL",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_APP_NAME",
    "MINIO_ENDPOINT",
    "MINIO_PORT",
    "MINIO_USE_SSL",
    "MINIO_ACCESS_KEY",
    "MINIO_SECRET_KEY",
    "MINIO_BUCKET_AVATARS",
    "MINIO_BUCKET_FILES",
    "SMTP_HOST",
    "SMTP_PORT",
    "SMTP_USER",
    "SMTP_PASSWORD",
    "SMTP_FROM",
    "JUDGE0_API_URL",
    "JUDGE0_API_KEY"
  ],
  "globalDependencies": [".env", ".env.example"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "inputs": [
        "src/**",
        "public/**",
        "next.config.*",
        "tsconfig.json",
        "package.json",
        "prisma/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^db:generate"]
    },
    "lint": {
      "outputs": []
    },
    "type-check": {
      "dependsOn": ["^db:generate"],
      "outputs": []
    },
    "@lumibach/db#type-check": {
      "dependsOn": ["db:generate"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^db:generate"],
      "outputs": ["coverage/**"]
    },
    "db:generate": {
      "cache": false,
      "outputs": ["node_modules/.prisma/**", "src/generated/**"]
    },
    "db:migrate": {
      "cache": false,
      "persistent": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    }
  }
}
