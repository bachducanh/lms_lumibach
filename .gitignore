# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (monorepo)
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/

# production
build/
dist/

# turbo
.turbo/

# generated Prisma client (regenerated on install)
packages/db/generated/
# compiled package output (built on install)
packages/db/dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local
!.env.example

# IDE
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# OS
Thumbs.db

# Logs
logs/
*.log

# Uploads (dev)
uploads/

# vercel
.vercel

# typescript
*.tsbuildinfo
**/next-env.d.ts

# Claude Code
.claude/

# Scratch files
/scratch/

# Self-hosted scratch-gui — cloned source + build output
external/scratch-gui/
apps/web/public/scratch-gui/
