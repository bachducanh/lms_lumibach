# Test environment — used by `pnpm --filter @lumibach/api test`
# Postgres test container (docker-compose.test.yml) chạy port 5433, tmpfs.

NODE_ENV=test

DATABASE_URL="postgresql://lumibach_test:test_password@localhost:5433/lumibach_test?schema=public"

# AUTH_SECRET cho test — KHÁC prod để tránh nhầm. Test code dùng cùng secret này
# để sign fake JWT, sau đó NextAuthGuard sẽ verify.
AUTH_SECRET="test-secret-do-not-use-in-prod-32bytes-padding-padding"

# Sentry/Redis tắt trong test (không cần)
LOG_LEVEL=warn
API_PORT=4001
