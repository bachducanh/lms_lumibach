{
  "extends": "@lumibach/config/tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "ES2017",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "**/*.mts"],
  "exclude": ["node_modules", ".next", ".turbo"]
}
