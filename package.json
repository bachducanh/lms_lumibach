{
  "name": "lumibach",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @lumibach/db db:generate",
    "db:migrate": "pnpm --filter @lumibach/db db:migrate",
    "db:migrate:deploy": "pnpm --filter @lumibach/db db:migrate:deploy",
    "db:push": "pnpm --filter @lumibach/db db:push",
    "db:studio": "pnpm --filter @lumibach/db db:studio",
    "db:seed": "pnpm --filter @lumibach/db db:seed",
    "web:dev": "pnpm --filter @lumibach/web dev",
    "web:build": "pnpm --filter @lumibach/web build",
    "api:dev": "pnpm --filter @lumibach/api dev",
    "api:build": "pnpm --filter @lumibach/api build",
    "api:start": "pnpm --filter @lumibach/api start",
    "worker:dev": "pnpm --filter @lumibach/web worker:dev",
    "worker:email": "pnpm --filter @lumibach/web worker:email",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "test:api": "pnpm --filter @lumibach/api test",
    "prepare": "husky",
    "postinstall": "pnpm --filter @lumibach/db db:generate && pnpm --filter @lumibach/db build"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "turbo": "^2.3.0"
  }
}
